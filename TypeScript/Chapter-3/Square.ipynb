   "outputs": [],
   "source": [
    "function square(n: number): number {\n",
    "    if (n == 0) {\n",
    "        return 0;\n",
    "    }\n",
    "    return square(n - 1) + 2 * n - 1;\n",
    "}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b5f50d67",
   "metadata": {},
   "outputs": [],
   "source": [
    "for (let i = 0; i <= 11; ++i) {\n",
    "    console.log(`square(${i}) = ${square(i)}`);\n",
    "}"
   ]
  },
